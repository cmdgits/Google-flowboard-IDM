# ============================================================================
# OAUTH CONFIGURATION FOR SOCIAL MEDIA PLATFORMS
# ============================================================================

# ============================================================================
# TIKTOK CONFIGURATION
# ============================================================================
# Lấy từ: https://developers.tiktok.com/
# Cần:
#   - Client ID (App ID)
#   - Client Secret
#   - Redirect URI (phải match với backend)
# Dùng để: Post video lên TikTok
TIKTOK_CLIENT_ID=your_tiktok_client_id
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=http://localhost:8101/api/social/oauth/tiktok/callback

# ============================================================================
# FACEBOOK CONFIGURATION
# ============================================================================
# Lấy từ: https://developers.facebook.com/
# Cần:
#   - App ID (Client ID)
#   - App Secret (Client Secret)
#   - Redirect URI (phải match với backend)
# Lưu ý: Sẽ lấy Page ID + Page Access Token từ OAuth flow
# Dùng để: Post video lên Facebook Page
FACEBOOK_CLIENT_ID=your_facebook_app_id
FACEBOOK_CLIENT_SECRET=your_facebook_app_secret
FACEBOOK_REDIRECT_URI=http://localhost:8101/api/social/oauth/facebook/callback

# ============================================================================
# YOUTUBE CONFIGURATION
# ============================================================================
# Lấy từ: https://console.cloud.google.com/
# Cần:
#   - Client ID (OAuth 2.0 Client ID)
#   - Client Secret
#   - Redirect URI (phải match với backend)
# Dùng để: Upload video lên YouTube
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
YOUTUBE_REDIRECT_URI=http://localhost:8101/api/social/oauth/youtube/callback

# ============================================================================
# INSTAGRAM CONFIGURATION
# ============================================================================
# Lấy từ: https://developers.facebook.com/ (dùng Facebook Developer)
# Cần:
#   - App ID (Client ID)
#   - App Secret (Client Secret)
#   - Redirect URI (phải match với backend)
# Lưu ý: Sẽ lấy Instagram Business Account ID + Access Token từ OAuth flow
# Dùng để: Post video lên Instagram
INSTAGRAM_CLIENT_ID=your_instagram_app_id
INSTAGRAM_CLIENT_SECRET=your_instagram_app_secret
INSTAGRAM_REDIRECT_URI=http://localhost:8101/api/social/oauth/instagram/callback

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL=sqlite:///./flowboard.db

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=INFO

